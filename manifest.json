{
  "manifest_version": 3,
  "name": "Claude Code Status",
  "description": "Shows Claude Code service status in your browser toolbar",
  "version": "1.0.0",
  "permissions": [
    "alarms",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://status.claude.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Code Status",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
